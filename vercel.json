{
  "version": 2,
  "functions": {
    "api/claude.js":  { "maxDuration": 300 },
    "api/kirvano.js": { "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(js|css|json|png|jpg|jpeg|svg|ico|xml|txt|map))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
